{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "dest": "/main.py"
    },
    {
      "src": "^/(predictions|accuracy|health)$",
      "dest": "/main.py"
    },
    {
      "src": "^/(?!.*\\.(js|css|svg|png|jpg|jpeg|gif|ico|json|woff|woff2|ttf|eot|webp|webm|mp4|mp3)).*$",
      "dest": "/index.html"
    },
    {
      "src": "^/(.*\\.(js|css|svg|png|jpg|jpeg|gif|ico|json|woff|woff2|ttf|eot|webp|webm|mp4|mp3))$",
      "dest": "/$1"
    }
  ]
}
