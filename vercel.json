{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api(?:/(.*))?$",
      "dest": "/main.py"
    },
    {
      "src": "^/(predictions|accuracy|health)$",
      "dest": "/main.py"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "main.py": {
      "runtime": "python3.12"
    }
  },
  "build": {
    "env": {
      "PIP_ONLY_BINARY": ":all:"
    }
  }
}
